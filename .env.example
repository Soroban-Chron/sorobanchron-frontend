# Example environment variables for development

# Network
# NEXT_PUBLIC_NETWORK_URL=https://horizon-testnet.stellar.org
# NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Feature flags
# NEXT_PUBLIC_ENABLE_DEVTOOLS=true
# NEXT_PUBLIC_ENABLE_LOGGING=true

# API
# NEXT_PUBLIC_API_TIMEOUT_MS=30000

# Contract (when ready for deployment)
# NEXT_PUBLIC_SOROBANCHRON_CONTRACT_ADDRESS=C...
